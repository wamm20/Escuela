{
  "compileOnSave": false,
  "compilerOptions": {
    "outDir": "./dist/out-tsc",
    "rootDir": "./src",
    "sourceMap": true,
    "declaration": false,
    "experimentalDecorators": true,
    "ignoreDeprecations": "5.0",
    "moduleResolution": "bundler",
    "importHelpers": true,
    "target": "es2022",
    "module": "es2020",
    "skipLibCheck": true,
    "lib": ["es2020", "dom"]
  }
}
